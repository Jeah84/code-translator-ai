# ──────────────────────────────────────────────────────────────────────────────
# AI Provider
# ──────────────────────────────────────────────────────────────────────────────
# Which AI provider to use: "openai" | "anthropic"
AI_PROVIDER=openai

# ──────────────────────────────────────────────────────────────────────────────
# OpenAI
# ──────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ──────────────────────────────────────────────────────────────────────────────
# Anthropic (optional)
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ──────────────────────────────────────────────────────────────────────────────
# App settings
# ──────────────────────────────────────────────────────────────────────────────
# Base URL used for absolute links (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
